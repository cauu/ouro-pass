# Ouro Pass deployment configuration (S0009).
#
# Copy to .env and fill in — or run ./deploy/init.sh to generate .env with strong
# random secrets already filled. .env is gitignored; never commit real secrets.
#
# Values consumed by docker-compose.yml. A few OUROPASS_* knobs (ADDR, ISSUER,
# TRUSTED_PROXY, TLS, DB_DRIVER, DB_DSN) are DERIVED in docker-compose.yml from the
# variables here, so they are intentionally not listed below.

# ─── Public address & TLS (Caddy) ───────────────────────────────────────────
# Your public domain. Caddy gets a Let's Encrypt cert for it automatically and
# the issuer's token `iss` becomes https://${DOMAIN}. Must resolve to this host.
DOMAIN=pass.example.com
# Optional: email for ACME/Let's Encrypt expiry notices (recommended).
ACME_EMAIL=

# Issuer image tag pulled from GHCR (ghcr.io/cauu/ouro-pass).
# Pin a released version for reproducibility, e.g. 0.1.0 (note: the image tag has
# no leading "v" — git tag v0.1.0 publishes image tags 0.1.0 / 0.1 / latest).
OUROPASS_TAG=latest

# ─── Database (bundled Postgres) ─────────────────────────────────────────────
# Data is bind-mounted to ./data/postgres on the host. init.sh generates a strong
# POSTGRES_PASSWORD. For an external DB, see docker-compose.yml notes.
# NOTE: the password is interpolated into the DB connection URL, so use only
# URL-safe characters (no @ : / # % ? & space). init.sh's hex value is safe.
POSTGRES_USER=ouropass
POSTGRES_PASSWORD=
POSTGRES_DB=ouropass

# ─── Crypto secrets (REQUIRED — generate strong random; never reuse dev values) ─
# AES-256-GCM master key for 🔒 fields. 32 bytes hex = 64 chars. `openssl rand -hex 32`
OUROPASS_FIELD_KEY=
# HMAC salt for the pseudonymous `sub`. 16 bytes hex = 32 chars. `openssl rand -hex 16`
OUROPASS_SERVER_SALT=
# WARNING: rotating FIELD_KEY makes existing encrypted (🔒) fields unreadable.

# ─── Identity / network ──────────────────────────────────────────────────────
# Default network for NEW attestors created in the admin UI: mainnet|preprod|preview
OUROPASS_NETWORK=preprod

# ─── Chain data source ───────────────────────────────────────────────────────
# mock | koios | blockfrost | node_lsq | db_sync
OUROPASS_CHAIN_KIND=koios
# Koios base URL (federated/public or self-hosted). Examples:
#   mainnet:  https://api.koios.rest/api/v1
#   preprod:  https://preprod.koios.rest/api/v1
#   preview:  https://preview.koios.rest/api/v1
OUROPASS_KOIOS_BASE_URL=https://preprod.koios.rest/api/v1
# Optional API key (koios tiers / blockfrost project id). Blank = unauthenticated.
OUROPASS_CHAIN_API_KEY=
# Sovereign path (OUROPASS_CHAIN_KIND=node_lsq) — your own cardano-node socket.
# Requires mounting the node socket into the issuer container; see docs/deployment.md.
# OUROPASS_NODE_SOCKET=/ipc/node.socket
# OUROPASS_CARDANO_CLI=cardano-cli

# ─── Admin access ────────────────────────────────────────────────────────────
# Comma-separated owner stake-key hashes allowed to sign in to /admin as owner.
# Get yours: cd server && make stake-hash ADDR=stake1...   (REQUIRED to log in)
OUROPASS_OWNER_KEYS=

# ─── Telegram delivery (optional) ────────────────────────────────────────────
# Bot username (deep links) + bot API token. Leave blank to disable Telegram.
OUROPASS_TELEGRAM_BOT=
OUROPASS_TELEGRAM_TOKEN=
