# Ouro Pass reverse proxy (S0009). Caddy terminates TLS and proxies to the issuer;
# with a real public DOMAIN it auto-obtains/renews a Let's Encrypt cert — no extra
# config. DOMAIN is injected from .env.
#
# For certificate-expiry notices, set ACME_EMAIL in .env: the installer then
# prepends a global `{ email {$ACME_EMAIL} }` block here. Manual installs can add
# that block at the top themselves — note an EMPTY email value breaks Caddy.

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy issuer:8080
}
